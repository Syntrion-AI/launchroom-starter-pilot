# LaunchRoom SaaS Hermes profile environment example
#
# This file contains variable NAMES only. Do not commit real values.
# Copy to the user's private Hermes profile .env only when needed, then fill values outside chat.
# Prefer `hermes model`, `hermes setup`, `hermes auth`, or Hermes Desktop settings when available.
# Official references:
# - https://hermes-agent.nousresearch.com/docs/reference/environment-variables
# - https://hermes-agent.nousresearch.com/docs/integrations/providers
#
# If a provider/tool is missing here, check official docs first, then current public provider docs,
# then practical public sources such as GitHub issues/discussions. Record source and date in the setup report.

# --- Model providers / inference ---
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
GOOGLE_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
DASHSCOPE_API_KEY=
GLM_API_KEY=
KIMI_API_KEY=
MINIMAX_API_KEY=
HF_TOKEN=
OLLAMA_API_KEY=
OLLAMA_BASE_URL=
LM_API_KEY=
LM_BASE_URL=

# --- OAuth / special providers ---
# Prefer `hermes auth add <provider>` or `hermes model` where supported.
COPILOT_GITHUB_TOKEN=
COPILOT_CLI_PATH=
HERMES_COPILOT_ACP_COMMAND=

# --- GitHub / code hosting ---
GITHUB_TOKEN=
GH_TOKEN=

# --- Web/search/browser tools ---
FIRECRAWL_API_KEY=
BRAVE_SEARCH_API_KEY=
EXA_API_KEY=
BROWSER_USE_API_KEY=
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# --- Media / generation tools ---
FAL_KEY=
VOICE_TOOLS_OPENAI_KEY=
ELEVENLABS_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=

# --- Observability / AgentOps ---
HERMES_LANGFUSE_BASE_URL=
HERMES_LANGFUSE_PUBLIC_KEY=
HERMES_LANGFUSE_SECRET_KEY=

# --- Messaging / gateway, Stage 5 only ---
TELEGRAM_BOT_TOKEN=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
DISCORD_BOT_TOKEN=
MATRIX_ACCESS_TOKEN=
NTFY_TOKEN=

# --- MCP / remote runtime, gated stages only ---
# Put server-specific secrets in the user's private environment or approved secret store.
# Do not paste MCP credentials into chat or commit raw MCP JSON with secret env values.
